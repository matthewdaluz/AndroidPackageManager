# APM (apmd) init for LineageOS flashable deployment
# Starts after amsd publishes amsd.ready=1.

on init
    # Boot-level fallback so new sh/mksh/bash shells source APM PATH hooks
    # even before /data/local/tmp/apm/path files are generated.
    export ENV /system/bin/apm-sh-path
    export BASH_ENV /system/bin/apm-bash-path

on post-fs-data
    mkdir /data/apm 0775 root shell
    mkdir /data/local/tmp/apm 0775 root shell
    mkdir /data/local/tmp/apm/bin 0775 root shell
    mkdir /data/apm/cache 0775 root shell
    mkdir /data/apm/lists 0775 root shell
    mkdir /data/apm/keys 0775 root shell
    mkdir /data/apm/pkgs 0775 root shell
    mkdir /data/apm/sources 0775 root shell
    mkdir /data/apm/sources/sources.list.d 0775 root shell
    mkdir /data/apm/sandbox 0775 root shell
    mkdir /data/apm/sandbox/state 0775 root shell
    mkdir /data/apm/sandbox/env 0775 root shell
    mkdir /data/apm/sandbox/mounts 0775 root shell
    mkdir /data/apm/.security 0700 root root
    chown root shell /data/apm
    chmod 0775 /data/apm
    chown root shell /data/local/tmp/apm
    chmod 0775 /data/local/tmp/apm

    # Avoid stale binaries/scripts in /data/local/tmp/apm/bin shadowing /system/bin/apm*
    # for shell sessions with PATH hooks enabled.
    rm /data/local/tmp/apm/bin/apm
    rm /data/local/tmp/apm/bin/apmd
    rm /data/local/tmp/apm/bin/amsd
    rm /data/local/tmp/apm/apmd.sock
    rm /data/apm/apmd.sock
    restorecon_recursive /data/local/tmp/apm
    restorecon_recursive /data/apm

service apmd /system/bin/apmd
    class core
    user root
    group root system inet shell
    # Compatibility mode: keep su domain unless custom policy merge is guaranteed.
    seclabel u:r:su:s0
    capabilities SYS_ADMIN NET_ADMIN NET_RAW DAC_OVERRIDE DAC_READ_SEARCH CHOWN FOWNER SETUID SETGID

on property:amsd.ready=1
    start apmd

on property:apm.restart=1
    restart apmd
