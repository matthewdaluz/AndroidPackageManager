# APM/AMSD file contexts
# Requires the matching custom policy types declared in apm.cil.

# Binaries
/system/bin/apm                                 u:object_r:system_file:s0
/system/bin/apmd                                u:object_r:apmd_exec:s0
/system/bin/amsd                                u:object_r:amsd_exec:s0
/system/bin/apm-sh-path                         u:object_r:system_file:s0
/system/bin/apm-bash-path                       u:object_r:system_file:s0

# Runtime data trees
/data/apm(/.*)?                                 u:object_r:apm_data_file:s0
/data/ams(/.*)?                                 u:object_r:ams_data_file:s0

# Runtime sockets
/data/apm/apmd\.sock                            u:object_r:apmd_socket:s0
/data/ams/amsd\.sock                            u:object_r:amsd_socket:s0

# apmd-managed shell/profile integration targets
/data/local/userinit\.sh                        u:object_r:system_data_file:s0
/data/local/tmp/apm(/.*)?                       u:object_r:shell_data_file:s0
/data/apm/path(/.*)?                            u:object_r:apm_data_file:s0
/data/local/tmp/\.profile                       u:object_r:system_data_file:s0
/data/local/tmp/\.mkshrc                        u:object_r:system_data_file:s0
/data/local/tmp/\.bashrc                        u:object_r:system_data_file:s0
/data/local/tmp/\.bash_profile                  u:object_r:system_data_file:s0
/data/\.profile                                 u:object_r:system_data_file:s0
/data/\.mkshrc                                  u:object_r:system_data_file:s0
/data/\.bashrc                                  u:object_r:system_data_file:s0
/data/\.bash_profile                            u:object_r:system_data_file:s0
/data/local/tmp/apm-apk-staging(/.*)?           u:object_r:system_data_file:s0
