on post-fs-data
    mkdir /data/apm 0775 root shell
    mkdir /data/apm/bin 0775 root shell
    mkdir /data/apm/cache 0775 root shell
    mkdir /data/apm/lists 0775 root shell
    mkdir /data/apm/keys 0775 root shell
    mkdir /data/apm/pkgs 0775 root shell
    mkdir /data/apm/installed 0775 root shell
    mkdir /data/apm/installed/commands 0775 root shell
    mkdir /data/apm/installed/dependencies 0775 root shell
    mkdir /data/apm/installed/termux 0775 root shell
    mkdir /data/apm/installed/termux/bin 0775 root shell
    mkdir /data/apm/installed/termux/lib 0775 root shell
    mkdir /data/apm/installed/termux/lib64 0775 root shell
    mkdir /data/apm/installed/termux/lib32 0775 root shell
    mkdir /data/apm/installed/termux/opt 0775 root shell
    mkdir /data/apm/installed/termux/mnt 0775 root shell
    mkdir /data/apm/installed/termux/var 0775 root shell
    mkdir /data/apm/installed/termux/etc 0775 root shell
    mkdir /data/apm/installed/termux/tmp 0775 root shell
    mkdir /data/apm/installed/termux/usr 0775 root shell
    mkdir /data/apm/installed/termux/home 0775 root shell
    mkdir /data/apm/installed/termux/usr/bin 0775 root shell
    mkdir /data/apm/installed/termux/usr/lib 0775 root shell
    mkdir /data/apm/installed/termux/usr/lib64 0775 root shell
    mkdir /data/apm/installed/termux/usr/lib32 0775 root shell
    mkdir /data/apm/installed/termux/usr/libexec 0775 root shell
    mkdir /data/apm/installed/termux/usr/include 0775 root shell
    mkdir /data/apm/installed/termux/usr/share 0775 root shell
    mkdir /data/apm/installed/termux/usr/etc 0775 root shell
    mkdir /data/apm/installed/termux/usr/opt 0775 root shell
    mkdir /data/apm/installed/termux/usr/var 0775 root shell
    mkdir /data/apm/installed/termux/usr/tmp 0775 root shell
    mkdir /data/apm/logs 0775 root shell
    mkdir /data/apm/logs/modules 0775 root shell
    mkdir /data/apm/sources 0775 root shell
    mkdir /data/apm/sources/sources.list.d 0775 root shell
    mkdir /data/apm/manual-packages 0775 root shell
    mkdir /data/apm/modules 0775 root shell
    mkdir /data/apm/modules/.runtime 0700 root shell
    mkdir /data/apm/modules/.runtime/upper 0700 root shell
    mkdir /data/apm/modules/.runtime/work 0700 root shell
    mkdir /data/apm/modules/.runtime/base 0700 root shell
    mkdir /data/apm/.security 0700 root root
    mkdir /data/ams 0775 root shell
    mkdir /data/ams/modules 0775 root shell
    mkdir /data/ams/overlays 0775 root shell
    mkdir /data/ams/merged 0775 root shell
    mkdir /data/apm-system-overlay 0755 root root
    mkdir /data/apm-system-overlay/system 0755 root root
    mkdir /data/apm-system-overlay/system/bin 0755 root root
    mkdir /data/apm-system-overlay/init 0755 root root
    mkdir /data/apm-system-overlay/sepolicy 0755 root root
    mkdir /data/apm-system-overlay/logs 0755 root root
    start apmd-setup
    # apmd will be started by init on boot completion; no polling restarts

service apmd-setup /system/bin/sh -c '\
    BASE=/data/apm; \
    OVERLAY=/data/apm-system-overlay; \
    BIN_DIR="$OVERLAY/system/bin"; \
    DATA_BIN="$BASE/bin"; \
    INIT_SRC="$OVERLAY/init/init.apmd.rc"; \
    SEPOLICY_DIR="$OVERLAY/sepolicy"; \
    POLICY_BIN="/data/apm/bin/magiskpolicy"; \
    LOG_DIR="$BASE/logs"; \
    LOG_FILE="$LOG_DIR/bootstrap.log"; \
    mkdir -p "$LOG_DIR"; \
    touch "$LOG_FILE"; \
    chmod 0644 "$LOG_FILE"; \
    log() { echo "$(date +%F\ %T) - $*" >>"$LOG_FILE"; }; \
    log "apmd bootstrap starting"; \
    for f in "$BIN_DIR"/*; do \
        [ -f "$f" ] || continue; \
        chmod 0755 "$f"; \
        chown root:root "$f"; \
        if command -v chcon >/dev/null 2>&1; then \
            chcon u:object_r:system_file:s0 "$f" 2>/dev/null || true; \
        fi; \
    done; \
    if [ -x "$DATA_BIN/magiskpolicy" ]; then \
        chmod 0755 "$DATA_BIN/magiskpolicy"; \
        chown root:root "$DATA_BIN/magiskpolicy"; \
        if command -v chcon >/dev/null 2>&1; then \
            chcon u:object_r:system_file:s0 "$DATA_BIN/magiskpolicy" 2>/dev/null || true; \
        fi; \
    fi; \
    if [ -f "$INIT_SRC" ]; then \
        chmod 0644 "$INIT_SRC"; \
        chown root:root "$INIT_SRC"; \
        if command -v chcon >/dev/null 2>&1; then \
            chcon u:object_r:system_file:s0 "$INIT_SRC" 2>/dev/null || true; \
        fi; \
    fi; \
    if [ -d "$SEPOLICY_DIR" ]; then \
        for te in "$SEPOLICY_DIR"/*.te; do \
            [ -f "$te" ] || continue; \
            chown root:root "$te"; \
            chmod 0644 "$te"; \
            if command -v chcon >/dev/null 2>&1; then \
                chcon u:object_r:system_file:s0 "$te" 2>/dev/null || true; \
            fi; \
            if [ -x "$POLICY_BIN" ]; then \
                "$POLICY_BIN" --live --apply "$te" >>"$LOG_FILE" 2>&1 || log "magiskpolicy failed for $te"; \
            else \
                log "magiskpolicy missing; skipped $te"; \
            fi; \
        done; \
    fi; \
    if command -v restorecon >/dev/null 2>&1; then \
        restorecon -RF "$BASE" /data/ams "$OVERLAY" 2>/dev/null || true; \
    fi; \
    for bin in "$BIN_DIR"/*; do \
        [ -f "$bin" ] || continue; \
        name=$(basename "$bin"); \
        for dst_base in /system /mnt/system; do \
            [ -d "$dst_base/bin" ] || continue; \
            dst="$dst_base/bin/$name"; \
            [ -e "$dst" ] || touch "$dst" 2>/dev/null || { log "Unable to create $dst"; continue; }; \
            if grep -q " $dst " /proc/mounts 2>/dev/null; then \
                continue; \
            fi; \
            if mount -o bind "$bin" "$dst" 2>/dev/null || mount --bind "$bin" "$dst" 2>/dev/null; then \
                log "Bind mounted $bin -> $dst"; \
            else \
                log "Failed to bind $bin -> $dst"; \
            fi; \
        done; \
    done; \
    # Startup of apmd is managed via init triggers (see below); avoid property-based loops \ 
    log "apmd setup completed"; \
    exit 0'
    class late_start
    oneshot
    user root
    group root system shell
    disabled
    seclabel u:r:init:s0

service apmd /system/bin/apmd
    class late_start
    user root
    group root system inet shell
    disabled
    seclabel u:r:init:s0

# Start apmd once the system reports boot completed
on property:sys.boot_completed=1
    start apmd

# Rate-limit restarts to avoid rapid loops if apmd crashes
service apmd /system/bin/apmd
    restart_period 120
