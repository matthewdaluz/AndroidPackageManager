CompileFlags:
  Add:
    - -std=c++17
    - -Wall
    - -Wextra
    - -Wno-unused-parameter
    - -Wno-unused-variable

# Make Clangd use compile_commands.json
# (CMake will generate this automatically)

Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: Strict
  Suppress:
    - unused-variable
    - unused-parameter
    - missing-prototypes

