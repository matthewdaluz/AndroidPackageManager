CompileFlags:
  CompilationDatabase: build
  Add:
    - -std=c++17
    - -Wall
    - -Wextra
    - -Wno-unused-parameter
    - -Wno-unused-variable

# Build scripts write compile_commands.json into build/
# and publish a workspace-root copy/symlink for editor compatibility.

Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: Strict
  Suppress:
    - unused-variable
    - unused-parameter
    - missing-prototypes
