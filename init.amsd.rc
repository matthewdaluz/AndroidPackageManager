# AMSD init script - provisions /ams hierarchy and launches amsd early

on init
    mkdir /ams 0755 root root
    mkdir /ams/modules 0755 root root
    mkdir /ams/logs 0755 root root
    mkdir /ams/.runtime 0700 root root
    mkdir /ams/.runtime/upper 0700 root root
    mkdir /ams/.runtime/work 0700 root root
    mkdir /ams/.runtime/base 0700 root root

service amsd /system/bin/amsd
    class core
    user root
    group root system
    seclabel u:r:init:s0
    socket amsd stream 0666 root root
    restart_period 90
