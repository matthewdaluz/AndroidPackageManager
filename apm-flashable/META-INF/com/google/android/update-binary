#!/sbin/sh

# APM flashable installer for modern system-as-root devices.
# Recovery is FBE-limited: we only write to /mnt/system, never /data.
# All runtime installation happens during Android boot (post-fs-data).

OUTFD="$2"
ZIPFILE="$3"

STAGING_BASE="/mnt/system/apm-staging"
STAGING_BIN="$STAGING_BASE/bin"
STAGING_SEPOLICY="$STAGING_BASE/sepolicy"
STAGING_SCRIPTS="$STAGING_BASE/scripts"
INIT_DST="/mnt/system/etc/init"
INIT_RC="$INIT_DST/init.apmd.rc"

ui_print() {
  printf "ui_print %s\nui_print \n" "$1" > /proc/self/fd/"$OUTFD"
}

abort() {
  ui_print "Error: $1"
  exit 1
}

maybe_chcon() {
  local path="$1" ctx="$2"
  command -v chcon >/dev/null 2>&1 || return 0
  chcon "$ctx" "$path" 2>/dev/null || true
}

mount_system_rw() {
  if mountpoint -q /mnt/system; then
    mount -o rw,remount /mnt/system >/dev/null 2>&1 && return 0
  fi

  if mountpoint -q /system; then
    mount -o rw,remount /system >/dev/null 2>&1 && return 0
  fi

  mount -o rw,remount / >/dev/null 2>&1 && return 0
  return 0
}

ensure_dirs() {
  mkdir -p "$STAGING_BIN" \
           "$STAGING_SEPOLICY" \
           "$STAGING_SCRIPTS" \
           "$STAGING_BASE/init" \
           "$INIT_DST" || abort "Unable to create staging dirs"

  chown 0:0 "$STAGING_BASE" "$STAGING_BIN" "$STAGING_SEPOLICY" "$STAGING_SCRIPTS" "$STAGING_BASE/init" "$INIT_DST" 2>/dev/null || true
  chmod 0755 "$STAGING_BASE" "$STAGING_BIN" "$STAGING_SEPOLICY" "$STAGING_SCRIPTS" "$STAGING_BASE/init" "$INIT_DST" 2>/dev/null || true
}

install_init_rc() {
  unzip -o -j "$ZIPFILE" "system/etc/init/init.apmd.rc" \
    -d "$INIT_DST" >/dev/null 2>&1 || abort "Failed to place init.apmd.rc"

  chown 0:0 "$INIT_RC" 2>/dev/null || true
  chmod 0644 "$INIT_RC" 2>/dev/null || true
  maybe_chcon "$INIT_RC" "u:object_r:system_file:s0"
}

install_binaries() {
  unzip -o -j "$ZIPFILE" "system/bin/*" -d "$STAGING_BIN" >/dev/null 2>&1 || abort "Failed to extract binaries"
  chmod 0755 "$STAGING_BIN"/* 2>/dev/null || true
}

install_te_files() {
  unzip -o -j "$ZIPFILE" "sepolicy/*.te" -d "$STAGING_SEPOLICY" >/dev/null 2>&1 || true
  chmod 0644 "$STAGING_SEPOLICY"/*.te 2>/dev/null || true
}

write_boot_scripts() {
  cat >"$STAGING_SCRIPTS/apm-overlay.sh" <<'EOF'
#!/system/bin/sh
BASE="/data/apm-system-overlay"
BIN_DIR="$BASE/system/bin"
INIT_SRC="$BASE/init/init.apmd.rc"
LOG_DIR="$BASE/logs"
LOG_FILE="$LOG_DIR/overlay.log"
SYS_BASE="/mnt/system"
SYS_ALT="/system"

mkdir -p "$LOG_DIR"

log() {
  echo "$(date '+%F %T') - $*" >>"$LOG_FILE"
}

bind_mount() {
  local src="$1" dst="$2"
  if [ ! -e "$src" ]; then
    log "Skip missing $src"
    return 0
  fi

  mkdir -p "$(dirname "$dst")"
  if [ ! -e "$dst" ]; then
    touch "$dst" 2>/dev/null || log "Unable to create $dst"
  fi

  if grep -q " $dst " /proc/mounts 2>/dev/null; then
    log "Already mounted: $dst"
    return 0
  fi

  if mount -o bind "$src" "$dst" 2>/dev/null || mount --bind "$src" "$dst" 2>/dev/null; then
    log "Bind mounted $src -> $dst"
  else
    log "Failed to bind $src -> $dst"
  fi
}

log "Starting overlay bind mounts"
for bin in "$BIN_DIR"/*; do
  [ -f "$bin" ] || continue
  bind_mount "$bin" "$SYS_BASE/bin/$(basename "$bin")"
  if [ "$SYS_ALT" != "$SYS_BASE" ]; then
    bind_mount "$bin" "$SYS_ALT/bin/$(basename "$bin")"
  fi
done
bind_mount "$INIT_SRC" "$SYS_BASE/etc/init/init.apmd.rc"
if [ "$SYS_ALT" != "$SYS_BASE" ]; then
  bind_mount "$INIT_SRC" "$SYS_ALT/etc/init/init.apmd.rc"
fi
log "Overlay bind mounts complete"
exit 0
EOF

  cat >"$STAGING_SCRIPTS/apm-sepolicy.sh" <<'EOF'
#!/system/bin/sh
BASE="/data/apm-system-overlay"
TE_DIR="$BASE/sepolicy"
LOG_DIR="$BASE/logs"
LOG_FILE="$LOG_DIR/sepolicy.log"
SYS_BASE="/mnt/system"
SYS_ALT="/system"

mkdir -p "$LOG_DIR"

log() {
  echo "$(date '+%F %T') - $*" >>"$LOG_FILE"
}

log "Starting SELinux rule application"

if [ ! -d "$TE_DIR" ]; then
  log "No SELinux rules directory found; nothing to do"
  exit 0
fi

applied=0
for te in "$TE_DIR"/*.te; do
  [ -f "$te" ] || continue
  log "Applying $(basename "$te")"
  if [ -x "$SYS_BASE/bin/apm-policy" ] && "$SYS_BASE/bin/apm-policy" "$te" >>"$LOG_FILE" 2>&1; then
    log "Applied $(basename "$te")"
  elif [ "$SYS_ALT" != "$SYS_BASE" ] && [ -x "$SYS_ALT/bin/apm-policy" ] && "$SYS_ALT/bin/apm-policy" "$te" >>"$LOG_FILE" 2>&1; then
    log "Applied $(basename "$te") via alt path"
  else
    log "Failed to apply $(basename "$te")"
  fi
  applied=1
done

if [ "$applied" -eq 0 ]; then
  log "No .te files found to apply"
fi

log "apm-sepolicy finished"
exit 0
EOF

  chown 0:0 "$STAGING_SCRIPTS/apm-overlay.sh" "$STAGING_SCRIPTS/apm-sepolicy.sh" 2>/dev/null || true
  chmod 0755 "$STAGING_SCRIPTS/apm-overlay.sh" "$STAGING_SCRIPTS/apm-sepolicy.sh" 2>/dev/null || true
}

main() {
  ui_print "Installing APM (system staging)..."
  mount_system_rw
  ensure_dirs
  install_init_rc
  install_binaries
  install_te_files
  write_boot_scripts
  ui_print "Staging complete. Boot-time init will finalize installation."
  exit 0
}

main "$@"
