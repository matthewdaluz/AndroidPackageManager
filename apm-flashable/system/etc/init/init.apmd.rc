on post-fs-data
    # Create APM data directories
    mkdir /data/apm 0775 root shell
    mkdir /data/apm/bin 0775 root shell
    mkdir /data/apm/cache 0775 root shell
    mkdir /data/apm/lists 0775 root shell
    mkdir /data/apm/keys 0775 root shell
    mkdir /data/apm/pkgs 0775 root shell
    mkdir /data/apm/installed 0775 root shell
    mkdir /data/apm/installed/commands 0775 root shell
    mkdir /data/apm/installed/dependencies 0775 root shell
    mkdir /data/apm/installed/termux 0775 root shell
    mkdir /data/apm/installed/termux/bin 0775 root shell
    mkdir /data/apm/installed/termux/lib 0775 root shell
    mkdir /data/apm/installed/termux/lib64 0775 root shell
    mkdir /data/apm/installed/termux/lib32 0775 root shell
    mkdir /data/apm/installed/termux/opt 0775 root shell
    mkdir /data/apm/installed/termux/mnt 0775 root shell
    mkdir /data/apm/installed/termux/var 0775 root shell
    mkdir /data/apm/installed/termux/etc 0775 root shell
    mkdir /data/apm/installed/termux/tmp 0775 root shell
    mkdir /data/apm/installed/termux/usr 0775 root shell
    mkdir /data/apm/installed/termux/home 0775 root shell
    mkdir /data/apm/installed/termux/usr/bin 0775 root shell
    mkdir /data/apm/installed/termux/usr/lib 0775 root shell
    mkdir /data/apm/installed/termux/usr/lib64 0775 root shell
    mkdir /data/apm/installed/termux/usr/lib32 0775 root shell
    mkdir /data/apm/installed/termux/usr/libexec 0775 root shell
    mkdir /data/apm/installed/termux/usr/include 0775 root shell
    mkdir /data/apm/installed/termux/usr/share 0775 root shell
    mkdir /data/apm/installed/termux/usr/etc 0775 root shell
    mkdir /data/apm/installed/termux/usr/opt 0775 root shell
    mkdir /data/apm/installed/termux/usr/var 0775 root shell
    mkdir /data/apm/installed/termux/usr/tmp 0775 root shell
    mkdir /data/apm/logs 0775 root shell
    mkdir /data/apm/logs/modules 0775 root shell
    mkdir /data/apm/sources 0775 root shell
    mkdir /data/apm/sources/sources.list.d 0775 root shell
    mkdir /data/apm/manual-packages 0775 root shell
    mkdir /data/apm/modules 0775 root shell
    mkdir /data/apm/modules/.runtime 0700 root shell
    mkdir /data/apm/modules/.runtime/upper 0700 root shell
    mkdir /data/apm/modules/.runtime/work 0700 root shell
    mkdir /data/apm/modules/.runtime/base 0700 root shell
    mkdir /data/apm/.security 0700 root root
    mkdir /data/ams 0775 root shell
    mkdir /data/ams/modules 0775 root shell
    mkdir /data/ams/overlays 0775 root shell
    mkdir /data/ams/merged 0775 root shell

    # Restore SELinux contexts
    restorecon_recursive /data/apm
    restorecon_recursive /data/ams

service apmd /system/bin/apmd
    class late_start
    user root
    group root system inet shell
    # IPC-only: daemon binds /data/apm/apmd.sock itself
    seclabel u:r:apmd:s0
    capabilities NET_ADMIN NET_RAW SYS_MODULE SYS_ADMIN DAC_OVERRIDE DAC_READ_SEARCH
    # Auto-restart if crashes - oneshot is false to keep running
    restart
    # Ensure /data is mounted and writable before starting
    disabled

on property:sys.boot_completed=1
    # Start apmd once boot is complete and /data is fully ready
    start apmd
